# Fabbrica v3 — credenziali produzione corsi (copiare in .env.produzione, MAI committare)

# Azure OpenAI — deployment GPT-5 full (20M TPM, region UE)
AZURE_OPENAI_ENDPOINT=https://<risorsa>.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# Azure Speech (TTS) — risorsa in region UE (westeurope / northeurope)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
# Voce neurale it-IT scelta dall'utente (es. it-IT-GiuseppeMultilingualNeural)
AZURE_SPEECH_VOICE=
