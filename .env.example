# === Database (Supabase EU, eu-central-1) ===
# URL pooled per l'app, URL diretto per le migrazioni drizzle-kit
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres"
# Ruolo SQL solo-INSERT per l'audit log append-only (Modulo 6)
AUDIT_DB_ROLE="audit_writer"

# === Auth (better-auth) ===
BETTER_AUTH_SECRET="genera-una-stringa-casuale-lunga"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Dominio radice per i sottodomini multi-tenant B2B (dev: localhost:3000 / prod: tuodominio.com)
NEXT_PUBLIC_ROOT_DOMAIN="localhost:3000"

# === Supabase (Storage / client) ===
SUPABASE_URL="https://<project>.supabase.co"
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# === Stripe (subscription seat B2B + one-off B2C) ===
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# === Cloudflare Stream (video, signed URL) ===
